msgstr "Basculer en plein écran"

# Article dashboard (v0.11.0) — sentiment panel (server-rendered from
# Omeka item metadata via SentimentExtractor). Strings come from the
# retired IwacSentiment module so existing installations' translation
# memory keeps working.

msgid "AI sentiment"
msgstr "Sentiment IA"

msgid "Polarity"
msgstr "Polarité"

msgid "Centrality"
msgstr "Centralité"

msgid "Subjectivity"
msgstr "Subjectivité"

msgid "Show reasoning"
msgstr "Voir les justifications"

msgid "Model comparison"
msgstr "Comparaison des modèles"

msgid "Not rated"
msgstr "Non évalué"

msgid "desc_article_sentiment"
msgstr "Polarité, centralité à l’islam / aux musulmans et subjectivité attribuées à cet article par les trois évaluateurs IA (Gemini, ChatGPT, Mistral). Lues directement depuis les métadonnées de la notice Omeka."

msgid "Scales: polarity 1 (very negative) \u2013 5 (very positive) \u00B7 centrality 1 (not addressed) \u2013 5 (very central) \u00B7 subjectivity 1 (objective) \u2013 5 (subjective)"
msgstr "Échelles : polarité 1 (très négatif) – 5 (très positif) · centralité 1 (non abordé) – 5 (très central) · subjectivité 1 (objectif) – 5 (subjectif)"

