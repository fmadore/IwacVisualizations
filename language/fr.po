# Block layout labels

msgid "Knowledge Graph"
msgstr "Graphe de connaissances"

msgid "Visualizations"
msgstr "Visualisations"

msgid "Item Set Dashboard"
msgstr "Tableau de bord de la collection"

msgid "Collection Overview"
msgstr "Vue d’ensemble de la collection"

msgid "Compare Projects"
msgstr "Comparer des projets"

msgid "References Overview"
msgstr "Vue d’ensemble des références"

msgid "Person dashboard"
msgstr "Tableau de bord de la personne"

# Block layout form hints

msgid "Aggregate visualizations across the entire collection. No configuration needed."
msgstr "Visualisations agrégées sur l’ensemble de la collection. Aucune configuration nécessaire."

msgid "Side-by-side comparison of two projects. No configuration needed."
msgstr "Comparaison côte à côte de deux projets. Aucune configuration nécessaire."

msgid "Bibliographic references overview: timeline, types, top authors, and top subjects. Data is fetched live from Hugging Face. No configuration needed."
msgstr "Vue d’ensemble des références bibliographiques : frise chronologique, types, auteurs les plus cités et sujets récurrents. Les données sont récupérées en direct depuis Hugging Face. Aucune configuration nécessaire."

