<?php
/**
 * Knowledge Graph resource page block.
 *
 * Renders a lightweight container. All data fetching and graph building
 * happens asynchronously in JavaScript via the Omeka S REST API,
 * so the page loads instantly.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\ItemRepresentation $resource
 */

$this->headScript()->appendFile($this->assetUrl('js/knowledge-graph.js', 'IwacVisualizations'));

$siteSlug = $this->currentSite()->slug();
$resourceClass = $resource->resourceClass();
?>

<div class="resource-vis-block knowledge-graph-block">
    <h3><?= $this->translate('Knowledge Graph') ?></h3>
    <div class="knowledge-graph-toolbar">
        <button type="button" class="rv-btn rv-fullscreen-toggle" aria-label="<?= $this->escapeHtmlAttr($this->translate('Toggle fullscreen')) ?>">
            <span class="rv-icon-expand">&#x26F6;</span>
        </button>
    </div>
    <div class="knowledge-graph-container"
         data-item-id="<?= $resource->id() ?>"
         data-base-path="<?= $this->escapeHtmlAttr($this->basePath()) ?>"
         data-api-base="<?= $this->escapeHtmlAttr($this->basePath() . '/api') ?>"
         data-site-base="<?= $this->escapeHtmlAttr($this->basePath() . '/s/' . $siteSlug) ?>">
        <div class="rv-loading">
            <div class="rv-spinner"></div>
            <span><?= $this->translate('Loading knowledge graph…') ?></span>
        </div>
    </div>
</div>
