<?php
/**
 * Item Set Dashboard resource page block.
 *
 * Fetches all items in the item set and renders aggregated visualizations.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\ItemSetRepresentation $resource
 */

$itemSetId = $resource->id();
$allItems = [];
$page = 1;

do {
    $response = $this->api()->search('items', [
        'item_set_id' => $itemSetId,
        'per_page'    => 100,
        'page'        => $page,
    ]);
    $items = $response->getContent();
    $allItems = array_merge($allItems, $items);
    $page++;
} while (count($items) === 100);

if (empty($allItems)) {
    return;
}
?>

<div class="resource-vis-block dashboard-block">
    <?= $this->partial('common/resource-page-block-layout/partials/dashboard-charts', [
        'items' => $allItems,
    ]) ?>
</div>
