<?php
/**
 * Item Set Dashboard resource page block.
 *
 * Newspapers, Islamic periodicals, and countries exist as item sets on
 * islam.zmo.de, and `generate_compare_newspapers.py` already emits a
 * single-corpus aggregate JSON for each. This block reuses those
 * aggregates: `asset/js/charts/item-set-dashboard.js` matches the item
 * set's title against `compare-newspapers/index.json` (articles +
 * publications; newspapers before countries) and renders the matching
 * corpus as a one-sided dashboard — summary cards, items per year, top
 * subjects, spatial coverage, most frequent words.
 *
 * Item sets with no matching corpus remove the block client-side
 * (heading included) — the same silent-skip rule the Visualizations
 * block applies to unsupported templates — so admins can enable this
 * for ALL item sets safely.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\ItemSetRepresentation $resource
 */

echo $this->partial('common/iwac-block-shell', [
    'assets' => [
        'needs' => [
            'chartOptions' => true,
            'wordcloud'    => true,
        ],
        'orchestrator' => 'item-set-dashboard',
    ],
    'blockClass'   => 'iwac-vis-item-set',
    'heading'      => $this->translate('Visualizations'),
    'loading'      => $this->translate('Loading dashboard'),
    'loadingClass' => 'iwac-vis-item-set__loading',
    'data'         => [
        'item-set-id'    => $resource->id(),
        'item-set-title' => $resource->displayTitle(),
    ],
]);
