<?php
/**
 * Visualizations: person template partial.
 *
 * Renders an async container that the JS orchestrator (person-dashboard.js)
 * fills with dynamic panels by fetching
 * asset/data/person-dashboards/{o_id}.json. The header card has been
 * removed since the same metadata is already shown by Omeka above the
 * resource page block.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\ItemRepresentation $resource
 */

echo $this->partial('common/iwac-assets', [
    'blockCss' => 'person-dashboard',
    'needs' => [
        'maplibre'     => true,
        'chartOptions' => true,
        'facetButtons' => true,
        'table'        => true,
        'pagination'   => true,
        'layout'       => true,
    ],
    // Self-registering IIFE panels. Each file hangs a render function off
    // IWACVis.personDashboard. `dashboard-panels-bridge` MUST load after
    // every per-panel IIFE — it registers thin wrappers around them into
    // IWACVis.dashboardLayout so the orchestrator can dispatch via
    // declarative slot arrays.
    'panels' => [
        'person-dashboard/stats',
        'person-dashboard/facet',
        'person-dashboard/timeline',
        'person-dashboard/heatmap',
        'person-dashboard/newspapers',
        'person-dashboard/countries',
        'person-dashboard/topics',
        'person-dashboard/sentiment',
        'person-dashboard/network',
        'person-dashboard/cooccurrence',
        'person-dashboard/map',
        'shared/dashboard-panels-bridge',
    ],
    'orchestrator' => 'person-dashboard',
]);

$siteSlug = $this->currentSite()->slug();
$escapeAttr = $this->plugin('escapeHtmlAttr');
?>

<div class="iwac-vis-block iwac-vis-person"
     data-item-id="<?= $escapeAttr($resource->id()) ?>"
     data-base-path="<?= $escapeAttr($this->basePath()) ?>"
     data-site-base="<?= $escapeAttr($this->basePath() . '/s/' . $siteSlug) ?>">

    <h3><?= $this->translate('Visualizations') ?></h3>

    <div class="iwac-vis-loading iwac-vis-person__loading">
        <div class="iwac-vis-spinner"></div>
        <span><?= $this->translate('Loading dashboard') ?>&hellip;</span>
    </div>
</div>
