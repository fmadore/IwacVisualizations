<?php
/**
 * Visualizations: minimal per-item partial.
 *
 * Dispatched by ``Visualizations::TEMPLATE_PARTIALS`` for resource
 * templates that don't have a dedicated dashboard but still benefit
 * from a small "where does this item sit in the corpus" view:
 *
 *   * 9  Audio              → ``audiovisual`` subset
 *   * 19 Video recording    → ``audiovisual`` subset
 *   * 22 Document           → ``documents`` subset
 *
 * The orchestrator (``minimal-item-dashboard.js``) loads
 * ``files/iwac-visualizations/template-summary.json``, picks the matching subset's
 * slice, and renders two slots through the v0.16.0 dashboardLayout
 * system:
 *
 *   1. Sibling sparkline — year histogram for the whole subset, with
 *      a dot at the current item's year (no ECharts; pure inline SVG).
 *   2. Similar-items strip — the most-recent N items in the subset
 *      excluding this one. The strip is the same renderer the Topic
 *      Explorer + per-article dashboard use; absent similarity scores
 *      it just renders plain link cards.
 *
 * Server side renders only the asynchronous container — Omeka already
 * shows the item's bibliographic metadata above the block, so we don't
 * duplicate it.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\ItemRepresentation $resource
 */

// Template ID → HF subset that drives the sibling context.
//
// audiovisual (45 items) is small enough that we use the WHOLE subset
// as siblings for both Audio (9) and Video (19) pages — the
// HF `medium` column carries physical-format labels (DVD / CD) rather
// than a clean audio/video split, so a per-medium filter would yield
// uneven slices (43 vs 1). When the upstream pipeline emits cleaner
// per-template tagging we can switch to the by_medium / by_type
// slices already present in template-summary.json.
//
// documents (26 items) is fully typed `Document` in the current
// dataset, so Document (22) reads from the whole documents subset.
// (Photograph (15) was mapped to `documents` until v1.3.0 — removed:
// photographs aren't in the HF dataset, so the slice was unrelated.)
$templateMap = [
    9  => 'audiovisual',
    19 => 'audiovisual',
    22 => 'documents',
];

$template   = $resource->resourceTemplate();
$templateId = $template ? (int) $template->id() : 0;
$subset     = $templateMap[$templateId] ?? '';

// Pull the current item's year out of dcterms:date so the sparkline
// can place the highlight dot. Bare-year and full ISO dates both
// work; missing dates leave the dot off.
$pubYear = '';
$dateValue = $resource->value('dcterms:date');
if ($dateValue) {
    $dateStr = (string) $dateValue;
    if (preg_match('/^(\d{4})/', $dateStr, $m)) {
        $pubYear = $m[1];
    }
}

echo $this->partial('common/iwac-block-shell', [
    'assets' => [
        'blockCss' => 'minimal-item',
        'needs' => [
            'chartOptions' => true,
            'layout'       => true,
            'renderers'    => [
                'sibling-sparkline',
                'similar-items',
            ],
        ],
        'orchestrator' => 'minimal-item-dashboard',
    ],
    'blockClass'   => 'iwac-vis-minimal-item',
    'heading'      => $this->translate('Visualizations'),
    'loading'      => $this->translate('Loading visualizations'),
    'loadingClass' => 'iwac-vis-minimal-item__loading',
    'data'         => [
        'item-id'     => $resource->id(),
        'template-id' => $templateId,
        'subset'      => $subset,
        'pub-year'    => $pubYear,
    ],
]);
