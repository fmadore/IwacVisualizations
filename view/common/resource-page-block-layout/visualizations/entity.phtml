<?php
/**
 * Visualizations: shared partial for non-person entities.
 *
 * Drives the dashboard for Lieux (template 6), Organisations (7),
 * Sujets (3), and Événements (2). Each of those item types resolves
 * to this partial via Visualizations::TEMPLATE_PARTIALS, fetches
 * asset/data/entity-dashboards/{o_id}.json, and renders the same
 * panel set as the person dashboard MINUS the role facet bar (subject
 * vs creator only makes sense for persons).
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\ItemRepresentation $resource
 */

echo $this->partial('common/iwac-assets', [
    'blockCss' => 'person-dashboard',
    'needs' => [
        'maplibre'     => true,
        'chartOptions' => true,
        'facetButtons' => true,
        'table'        => true,
        'pagination'   => true,
    ],
    // Reuse the person panel modules: the entity precompute wraps every
    // section in `by_role.all` precisely so these modules work unchanged
    // with a no-op facet provided by entity-dashboard.js. Same source
    // files load on person and entity pages — zero forked panel JS.
    // `facet.js` is omitted here because entities don't have a role
    // facet bar.
    'panels' => [
        'person-dashboard/stats',
        'person-dashboard/timeline',
        'person-dashboard/heatmap',
        'person-dashboard/newspapers',
        'person-dashboard/countries',
        'person-dashboard/topics',
        'person-dashboard/sentiment',
        'person-dashboard/network',
        'person-dashboard/cooccurrence',
        'person-dashboard/map',
    ],
    'orchestrator' => 'entity-dashboard',
]);

$siteSlug = $this->currentSite()->slug();
$escapeAttr = $this->plugin('escapeHtmlAttr');
?>

<div class="iwac-vis-block iwac-vis-entity"
     data-item-id="<?= $escapeAttr($resource->id()) ?>"
     data-base-path="<?= $escapeAttr($this->basePath()) ?>"
     data-site-base="<?= $escapeAttr($this->basePath() . '/s/' . $siteSlug) ?>">

    <h3><?= $this->translate('Visualizations') ?></h3>

    <div class="iwac-vis-loading iwac-vis-entity__loading">
        <div class="iwac-vis-spinner"></div>
        <span><?= $this->translate('Loading dashboard') ?>&hellip;</span>
    </div>
</div>
