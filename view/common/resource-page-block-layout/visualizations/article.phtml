<?php
/**
 * Visualizations: per-article partial.
 *
 * Renders when attached to an item whose resource template is
 * bibo:Article (template id 8 on islam.zmo.de). Dispatched here by
 * Visualizations::TEMPLATE_PARTIALS. Hybrid data path:
 *
 *   1. Sentiment          — extracted server-side from Omeka item
 *                           metadata (iwac:<model><Axis>) via
 *                           SentimentExtractor. Rendered directly into
 *                           PHP cards here; a small ECharts radar
 *                           below compares the three models.
 *
 *   2. Everything else    — fetched client-side from the precomputed
 *                           asset/data/article-dashboards/{o_id}.json
 *                           (context network, related articles,
 *                           similar articles, spatial coverage).
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\ItemRepresentation $resource
 */

use IwacVisualizations\Site\ResourcePageBlockLayout\SentimentExtractor;

echo $this->partial('common/iwac-assets', [
    // Base dashboard sheet (network toolbar, chord, map styling shared
    // with person + entity views). Article-specific layout (card
    // grids, sentiment cards) lives in css/blocks/article-dashboard.css
    // which we enqueue below.
    'blockCss' => 'person-dashboard',
    'needs' => [
        'maplibre'     => true,
        'chartOptions' => true,
        'facetButtons' => true,
        'table'        => true,
        'pagination'   => true,
    ],
    // Self-registering IIFEs for the client-side panels. The sentiment
    // panel is rendered server-side and is NOT included here — see
    // the <section> further down for its static markup. The radar
    // panel self-initialises from the inline JSON script we emit
    // below (article-dashboard/radar.js scans for it).
    'panels' => [
        'article-dashboard/network',
        'article-dashboard/further-reading',
        'article-dashboard/radar',
    ],
    'orchestrator' => 'article-dashboard',
]);

$this->headLink()->appendStylesheet(
    $this->assetUrl('css/blocks/article-dashboard.css', 'IwacVisualizations')
);

$siteSlug   = $this->currentSite()->slug();
$escapeAttr = $this->plugin('escapeHtmlAttr');
$escapeHtml = $this->plugin('escapeHtml');
$translate  = $this->plugin('translate');
$assetUrl   = $this->plugin('assetUrl');

// ---- Sentiment extraction (server-side from Omeka metadata) ----
$sentiment    = SentimentExtractor::fromItem($resource);
$hasSentiment = SentimentExtractor::hasAny($sentiment);

// Per-model chrome: precise model names (with release / parameter
// detail the user wants to see) + logos. Kept here, not in the
// extractor, because it's presentation metadata not data.
$modelInfo = [
    'gemini' => [
        'name'  => 'Gemini 3 Flash',
        'org'   => 'Google',
        'short' => 'Gemini',
        'logo'  => 'Gemini_logo.svg',
    ],
    'chatgpt' => [
        'name'  => 'GPT-5 mini',
        'org'   => 'OpenAI',
        'short' => 'GPT-5 mini',
        'logo'  => 'ChatGPT_logo.svg',
    ],
    'mistral' => [
        'name'  => 'Ministral 14B',
        'org'   => 'Mistral AI',
        'short' => 'Ministral 14B',
        'logo'  => 'Mistral_AI_logo.svg',
    ],
];

// CSS-class slug used by the .iwac-vis-chip--polarity-<slug>
// colouring rules. English "Very positive" → "very-positive".
$slug = function (?string $label): string {
    if (!$label) return '';
    return strtolower(str_replace(' ', '-', $label));
};

// Render the centrality dot scale as a small reusable closure so the
// card markup below stays readable.
$dots = function (int $level, int $max = 5) {
    $out = '';
    for ($i = 0; $i < $max; $i++) {
        $filled = $i < $level;
        $out .= '<span class="iwac-vis-dot ' . ($filled ? 'iwac-vis-dot--on' : 'iwac-vis-dot--off') . '" aria-hidden="true"></span>';
    }
    return '<span class="iwac-vis-dots" role="img" aria-label="' . (int) $level . ' / ' . (int) $max . '">' . $out . '</span>';
};

// Translated radar dimension labels + numeric datasets — serialised
// for the ECharts radar panel via the standard
// `<script type="application/json">` contract used throughout the
// module.
$radarData = [
    'labels' => [
        $translate('Polarity'),
        $translate('Centrality'),
        $translate('Subjectivity'),
    ],
    'models' => [],
];
foreach (SentimentExtractor::MODELS as $m) {
    $s = $sentiment[$m];
    $radarData['models'][] = [
        'key'               => $m,
        'label'             => $modelInfo[$m]['short'],
        'polarite'          => $s['polarite_numeric'] ?? 0,
        'centralite'        => $s['centralite_numeric'] ?? 0,
        'subjectivite'      => $s['subjectivite_score'] ?? 0,
        'polariteLabel'     => $s['polarite']           ? $translate($s['polarite'])           : '',
        'centraliteLabel'   => $s['centralite']         ? $translate($s['centralite'])         : '',
        'subjectiviteLabel' => $s['subjectivite_label'] ? $translate($s['subjectivite_label']) : '',
    ];
}
?>

<div class="iwac-vis-block iwac-vis-article"
     data-item-id="<?= $escapeAttr($resource->id()) ?>"
     data-base-path="<?= $escapeAttr($this->basePath()) ?>"
     data-site-base="<?= $escapeAttr($this->basePath() . '/s/' . $siteSlug) ?>">

    <h3><?= $translate('Visualizations') ?></h3>

    <div class="iwac-vis-loading iwac-vis-article__loading">
        <div class="iwac-vis-spinner"></div>
        <span><?= $translate('Loading dashboard') ?>&hellip;</span>
    </div>

    <?php if ($hasSentiment): ?>
    <section class="iwac-vis-panel iwac-vis-panel--wide iwac-vis-article__sentiment"
             data-iwac-no-panel-toolbar="1">
        <h4><?= $translate('AI sentiment') ?></h4>
        <p class="iwac-vis-panel-desc">
            <?= $translate('Polarity, centrality to Islam and Muslim communities, and subjectivity ratings for this article, produced by three AI models (Gemini 3 Flash, GPT-5 mini, Ministral 14B). Read directly from the Omeka item metadata.') ?>
        </p>

        <div class="iwac-vis-sent-cards">
            <?php foreach ($sentiment as $model => $s):
                if (!$s['rated']) continue;
                $info = $modelInfo[$model];
            ?>
            <article class="iwac-vis-sent-card iwac-vis-sent-card--<?= $escapeAttr($model) ?>">
                <header class="iwac-vis-sent-card__header">
                    <img class="iwac-vis-sent-card__logo"
                         src="<?= $escapeAttr($assetUrl('img/ai-logos/' . $info['logo'], 'IwacVisualizations')) ?>"
                         alt=""
                         width="22" height="22" loading="lazy">
                    <div class="iwac-vis-sent-card__names">
                        <h5 class="iwac-vis-sent-card__name"><?= $escapeHtml($info['name']) ?></h5>
                        <span class="iwac-vis-sent-card__org"><?= $escapeHtml($info['org']) ?></span>
                    </div>
                </header>

                <dl class="iwac-vis-sent-card__metrics">
                    <?php if ($s['polarite']): ?>
                    <div class="iwac-vis-sent-row">
                        <dt class="iwac-vis-sent-row__label"><?= $translate('Polarity') ?></dt>
                        <dd class="iwac-vis-sent-row__value">
                            <span class="iwac-vis-chip iwac-vis-chip--polarity iwac-vis-chip--polarity-<?= $escapeAttr($slug($s['polarite'])) ?>">
                                <?= $escapeHtml($translate($s['polarite'])) ?>
                            </span>
                        </dd>
                    </div>
                    <?php endif; ?>

                    <?php if ($s['centralite']): ?>
                    <div class="iwac-vis-sent-row">
                        <dt class="iwac-vis-sent-row__label"><?= $translate('Centrality') ?></dt>
                        <dd class="iwac-vis-sent-row__value iwac-vis-sent-row__value--inline">
                            <span class="iwac-vis-sent-row__text"><?= $escapeHtml($translate($s['centralite'])) ?></span>
                            <?= $dots((int) ($s['centralite_numeric'] ?? 0)) ?>
                        </dd>
                    </div>
                    <?php endif; ?>

                    <?php if (!empty($s['subjectivite_score'])): ?>
                    <div class="iwac-vis-sent-row">
                        <dt class="iwac-vis-sent-row__label"><?= $translate('Subjectivity') ?></dt>
                        <dd class="iwac-vis-sent-row__value">
                            <?php $subSlug = 'iwac-vis-chip--subjectivity-' . (int) $s['subjectivite_score']; ?>
                            <span class="iwac-vis-chip iwac-vis-chip--subjectivity <?= $escapeAttr($subSlug) ?>">
                                <?= $escapeHtml($s['subjectivite_label'] ? $translate($s['subjectivite_label']) : '') ?>
                            </span>
                        </dd>
                    </div>
                    <?php endif; ?>
                </dl>

                <?php
                    $hasJust = $s['polarite_justification']
                        || $s['centralite_justification']
                        || $s['subjectivite_justification'];
                ?>
                <?php if ($hasJust): ?>
                <details class="iwac-vis-sent-card__justifications">
                    <summary><?= $translate('Show reasoning') ?></summary>
                    <div class="iwac-vis-sent-just">
                        <?php if ($s['polarite_justification']): ?>
                        <div class="iwac-vis-sent-just__item">
                            <strong><?= $translate('Polarity') ?></strong>
                            <p><?= $escapeHtml($s['polarite_justification']) ?></p>
                        </div>
                        <?php endif; ?>
                        <?php if ($s['centralite_justification']): ?>
                        <div class="iwac-vis-sent-just__item">
                            <strong><?= $translate('Centrality') ?></strong>
                            <p><?= $escapeHtml($s['centralite_justification']) ?></p>
                        </div>
                        <?php endif; ?>
                        <?php if ($s['subjectivite_justification']): ?>
                        <div class="iwac-vis-sent-just__item">
                            <strong><?= $translate('Subjectivity') ?></strong>
                            <p><?= $escapeHtml($s['subjectivite_justification']) ?></p>
                        </div>
                        <?php endif; ?>
                    </div>
                </details>
                <?php endif; ?>
            </article>
            <?php endforeach; ?>
        </div>

        <!-- Radar chart — picked up by articleDashboard.radar (ECharts).
             Data is serialised below as JSON; the panel JS reads this
             script element by class and renders into the sibling
             `.iwac-vis-sent-radar__chart` div. -->
        <div class="iwac-vis-sent-radar">
            <h5 class="iwac-vis-sent-radar__title"><?= $translate('Model comparison') ?></h5>
            <div class="iwac-vis-sent-radar__chart" data-item-id="<?= $escapeAttr($resource->id()) ?>"></div>
            <script type="application/json" class="iwac-vis-sent-radar__data">
                <?= json_encode($radarData, JSON_HEX_TAG | JSON_HEX_AMP | JSON_UNESCAPED_UNICODE) ?>
            </script>
            <p class="iwac-vis-sent-radar__scale">
                <?= $translate('Scales: polarity 1 (very negative) – 5 (very positive) · centrality 1 (not addressed) – 5 (very central) · subjectivity 1 (objective) – 5 (subjective)') ?>
            </p>
        </div>
    </section>
    <?php endif; ?>
</div>
