<?php
/**
 * Shared dashboard chart rendering partial.
 *
 * Aggregates item data and renders chart containers.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\ItemRepresentation[] $items
 */

if (empty($items)) {
    return;
}

$this->headScript()->appendFile($this->assetUrl('js/dashboard-layouts.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-timeline.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-pie.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-bar.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-wordcloud.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-gantt.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-heatmap.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-chord.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-sankey.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-sunburst.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-stacked-timeline.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-beeswarm.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-map.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-collab-network.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-contributor-network.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-stacked-area.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-treemap.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-charts-geo-flows.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-registry.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard.js', 'IwacVisualizations'));

// Aggregate data from items.
$timeline     = [];
$types        = [];
$languages    = [];
$subjects     = [];
$contributors = [];

$dateProperties = ['dcterms:issued', 'dcterms:created', 'dcterms:date', 'fabio:hasDateCollected'];
$contributorPrefixes = ['marcrel:', 'dcterms:creator', 'dcterms:contributor'];

foreach ($items as $item) {
    // --- Timeline: extract year from first available date property ---
    foreach ($dateProperties as $prop) {
        $dateValue = $item->value($prop);
        if ($dateValue) {
            $dateStr = (string) $dateValue;
            if (preg_match('/(\d{4})/', $dateStr, $m)) {
                $year = $m[1];
                $timeline[$year] = ($timeline[$year] ?? 0) + 1;
            }
            break;
        }
    }

    // --- Resource types ---
    $typeValues = $item->value('dcterms:type', ['all' => true]);
    if ($typeValues) {
        foreach ($typeValues as $v) {
            $vr = $v->valueResource();
            $name = $vr ? $vr->displayTitle() : (string) $v;
            if ($name !== '') {
                $types[$name] = ($types[$name] ?? 0) + 1;
            }
        }
    }

    // --- Languages ---
    $langValues = $item->value('dcterms:language', ['all' => true]);
    if ($langValues) {
        foreach ($langValues as $v) {
            $vr = $v->valueResource();
            $name = $vr ? $vr->displayTitle() : (string) $v;
            if ($name !== '') {
                $languages[$name] = ($languages[$name] ?? 0) + 1;
            }
        }
    }

    // --- Subjects ---
    $subjectValues = $item->value('dcterms:subject', ['all' => true]);
    if ($subjectValues) {
        foreach ($subjectValues as $v) {
            $vr = $v->valueResource();
            $name = $vr ? $vr->displayTitle() : (string) $v;
            if ($name !== '') {
                $subjects[$name] = ($subjects[$name] ?? 0) + 1;
            }
        }
    }

    // --- Contributors: iterate all values to catch every marcrel:* ---
    foreach ($item->values() as $term => $propertyData) {
        $isContributor = false;
        foreach ($contributorPrefixes as $prefix) {
            if ($term === $prefix || strpos($term, $prefix) === 0) {
                $isContributor = true;
                break;
            }
        }
        if (!$isContributor) {
            continue;
        }
        foreach ($propertyData['values'] as $v) {
            $vr = $v->valueResource();
            $name = $vr ? $vr->displayTitle() : (string) $v;
            if ($name !== '') {
                $contributors[$name] = ($contributors[$name] ?? 0) + 1;
            }
        }
    }
}

ksort($timeline);
arsort($types);
arsort($languages);
arsort($subjects);
arsort($contributors);

$dashboardData = json_encode([
    'resourceType' => 'researchItem',
    'timeline'     => $timeline,
    'types'        => $types,
    'languages'    => $languages,
    'subjects'     => array_slice($subjects, 0, 60, true),
    'contributors' => array_slice($contributors, 0, 30, true),
    'totalItems'   => count($items),
], JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT);
?>

<div class="dashboard-header">
    <h3><?= $this->translate('Dashboard') ?></h3>
    <span class="dashboard-total">
        <?= sprintf($this->translatePlural('%d item', '%d items', count($items)), count($items)) ?>
    </span>
</div>

<div class="dashboard-container"
     data-dashboard="<?= $this->escapeHtmlAttr($dashboardData) ?>">
    <div class="dashboard-charts">
        <?php if (!empty($timeline)): ?>
        <div class="chart-panel chart-panel-wide">
            <h4><?= $this->translate('Timeline') ?></h4>
            <div class="chart-container" data-chart="timeline"></div>
        </div>
        <?php endif; ?>

        <?php if (!empty($types)): ?>
        <div class="chart-panel">
            <h4><?= $this->translate('Resource Types') ?></h4>
            <div class="chart-container" data-chart="types"></div>
        </div>
        <?php endif; ?>

        <?php if (!empty($languages)): ?>
        <div class="chart-panel">
            <h4><?= $this->translate('Languages') ?></h4>
            <div class="chart-container" data-chart="languages"></div>
        </div>
        <?php endif; ?>

        <?php if (!empty($subjects)): ?>
        <div class="chart-panel chart-panel-wide">
            <h4><?= $this->translate('Subjects') ?></h4>
            <div class="chart-container chart-container-tall" data-chart="subjects"></div>
        </div>
        <?php endif; ?>

        <?php if (!empty($contributors)): ?>
        <div class="chart-panel">
            <h4><?= $this->translate('Top Contributors') ?></h4>
            <div class="chart-container" data-chart="contributors"></div>
        </div>
        <?php endif; ?>
    </div>
</div>
