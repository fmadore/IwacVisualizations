<?php
/**
 * Compare Projects page block.
 *
 * Async container for side-by-side project comparison. Page blocks are
 * not served by the Item/ItemSet controllers, so this template has to
 * enqueue the module's assets itself.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\SitePageBlockRepresentation $block
 */

// Stylesheet
$this->headLink()->appendStylesheet(
    $this->assetUrl('css/iwac-visualizations.css', 'IwacVisualizations')
);

// CDN libraries
$this->headScript()->appendFile('https://cdn.jsdelivr.net/npm/echarts@6/dist/echarts.min.js');
$this->headScript()->appendFile('https://cdn.jsdelivr.net/npm/echarts-wordcloud@2/dist/echarts-wordcloud.min.js');
$this->headLink()->appendStylesheet('https://cdn.jsdelivr.net/npm/maplibre-gl@5/dist/maplibre-gl.css');
$this->headScript()->appendFile('https://cdn.jsdelivr.net/npm/maplibre-gl@5/dist/maplibre-gl.js');

// IWAC infrastructure — order matters: i18n → theme → core
$this->headScript()->appendFile($this->assetUrl('js/iwac-i18n.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/iwac-theme.js', 'IwacVisualizations'));
$this->headScript()->appendFile($this->assetUrl('js/dashboard-core.js', 'IwacVisualizations'));

$siteSlug = $this->currentSite()->slug();
?>

<div class="iwac-vis-block compare-block">
    <div class="compare-container"
         data-base-path="<?= $this->escapeHtmlAttr($this->basePath()) ?>"
         data-site-base="<?= $this->escapeHtmlAttr($this->basePath() . '/s/' . $siteSlug) ?>">
        <div class="iwac-vis-loading">
            <div class="iwac-vis-spinner"></div>
            <span><?= $this->translate('Loading project comparison') ?>&hellip;</span>
        </div>
    </div>
</div>
