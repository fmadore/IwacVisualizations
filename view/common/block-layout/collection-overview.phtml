<?php
/**
 * Collection Overview page block.
 *
 * Renders a bird's-eye summary of the whole IWAC collection: summary
 * cards, a stacked timeline, country + language distributions, and
 * top-N entities from the `index` authority subset with type tabs.
 *
 * The block is data-driven — it fetches
 * `asset/data/collection-overview.json`, which is generated by
 * `scripts/generate_collection_overview.py` from the Hugging Face
 * dataset `fmadore/islam-west-africa-collection`. See the project
 * README for the precompute workflow.
 *
 * Page blocks are not served by the Item/ItemSet controllers, so this
 * template has to enqueue the module's assets itself.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\SitePageBlockRepresentation $block
 */

// Stylesheet
$this->headLink()->appendStylesheet(
    $this->assetUrl('css/iwac-visualizations.css', 'IwacVisualizations')
);

// CDN libraries
$this->headScript()->appendFile('https://cdn.jsdelivr.net/npm/echarts@6/dist/echarts.min.js', 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile('https://cdn.jsdelivr.net/npm/echarts-wordcloud@2/dist/echarts-wordcloud.min.js', 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile('https://unpkg.com/maplibre-gl@5/dist/maplibre-gl.js', 'text/javascript', ['defer' => 'defer']);
$this->headLink()->appendStylesheet('https://unpkg.com/maplibre-gl@5/dist/maplibre-gl.css');

// IWAC infrastructure — order matters: i18n → theme → core → shared primitives → panels → orchestrator
$this->headScript()->appendFile($this->assetUrl('js/iwac-i18n.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/iwac-theme.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/dashboard-core.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);

// Shared primitives (panels.js first, then primitives that depend on it)
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/panels.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/panel-toolbar.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/responsive.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/chart-options.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/pagination.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/table.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/facet-buttons.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/maplibre.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);

// Collection Overview panels (self-registering IIFE modules)
$this->headScript()->appendFile($this->assetUrl('js/charts/collection-overview/recent-additions.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/collection-overview/entities.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/collection-overview/languages.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/collection-overview/growth.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/collection-overview/types-over-time.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/collection-overview/gantt.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/collection-overview/wordcloud.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/collection-overview/map.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);

// Orchestrator — LAST
$this->headScript()->appendFile($this->assetUrl('js/charts/collection-overview.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);

$siteSlug = $this->currentSite()->slug();
?>

<div class="iwac-vis-block iwac-vis-overview"
     data-base-path="<?= $this->escapeHtmlAttr($this->basePath()) ?>"
     data-site-base="<?= $this->escapeHtmlAttr($this->basePath() . '/s/' . $siteSlug) ?>">
    <div class="iwac-vis-loading">
        <div class="iwac-vis-spinner"></div>
        <span><?= $this->translate('Loading collection overview') ?>&hellip;</span>
    </div>
</div>
