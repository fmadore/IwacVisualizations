<?php
/**
 * Collection Overview page block.
 *
 * Renders a bird's-eye summary of the whole IWAC collection: summary
 * cards, a stacked timeline, country + language distributions, and
 * top-N entities from the `index` authority subset with type tabs.
 *
 * The block is data-driven — it fetches
 * `files/iwac-visualizations/collection-overview.json`, generated by
 * `scripts/generate_collection_overview.py` from the Hugging Face dataset
 * `fmadore/islam-west-africa-collection` and delivered by the admin Sync Data
 * job (issue #7). See the project README for the data-delivery workflow.
 *
 * Page blocks are not served by the Item/ItemSet controllers, so this
 * template delegates asset enqueueing to the shared `common/iwac-assets`
 * partial.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\SitePageBlockRepresentation $block
 */

// Server-render the headline summary from the precomputed snapshot so the
// block's marquee data is in the initial HTML — crawlers and no-JS / slow
// clients get real figures instead of a spinner, and the live ECharts
// dashboard (collection-overview.js) replaces it on hydration. Best-effort:
// any missing/unreadable/invalid snapshot falls back to the loading state,
// never a fatal. The snapshot is the same file the JS fetches over HTTP, read
// here from disk under files/iwac-visualizations/ (delivered by the Sync Data
// job, issue #7). Absent before the first data pull → the spinner shows.
$prerendered = '';
$snapshotPath = OMEKA_PATH . '/files/iwac-visualizations/collection-overview.json';
if (is_readable($snapshotPath)) {
    $snapshot = json_decode((string) file_get_contents($snapshotPath), true);
    if (is_array($snapshot) && !empty($snapshot['summary']) && is_array($snapshot['summary'])) {
        $prerendered = $this->partial('common/block-layout/collection-overview-fallback', [
            'summary' => $snapshot['summary'],
            'growth'  => (isset($snapshot['growth']) && is_array($snapshot['growth'])) ? $snapshot['growth'] : null,
        ]);
    }
}

echo $this->partial('common/iwac-block-shell', [
    'assets' => [
        'blockCss' => 'collection-overview',
        'needs' => [
            'maplibre'     => true,
            'wordcloud'    => true,
            'chartOptions' => true,
            'facetButtons' => true,
            'table'        => true,
            'pagination'   => true,
        ],
        'panels' => [
            'collection-overview/recent-additions',
            'collection-overview/entities',
            'collection-overview/languages',
            'collection-overview/growth',
            'collection-overview/types-over-time',
            'collection-overview/gantt',
            'collection-overview/wordcloud',
            'collection-overview/map',
            'collection-overview/sources-map',
        ],
        'orchestrator' => 'collection-overview',
    ],
    'blockClass'  => 'iwac-vis-overview',
    'loading'     => $this->translate('Loading collection overview'),
    'prerendered' => $prerendered,
]);
