// Orchestrator — LAST
$this->headScript()->appendFile($this->assetUrl('js/charts/index-overview.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);

$siteSlug = $this->currentSite()->slug();
?>

<div class="iwac-vis-block iwac-vis-index-overview"
     data-base-path="<?= $this->escapeHtmlAttr($this->basePath()) ?>"
     data-site-base="<?= $this->escapeHtmlAttr($this->basePath() . '/s/' . $siteSlug) ?>">
    <div class="iwac-vis-loading">
        <div class="iwac-vis-spinner"></div>
        <span><?= $this->translate('Loading index overview') ?>&hellip;</span>
    </div>
</div>
