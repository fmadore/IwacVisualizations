$this->headScript()->appendFile($this->assetUrl('js/charts/shared/panel-toolbar.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/responsive.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/chart-options.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/pagination.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/table.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/facet-buttons.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/maplibre.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/shared/map-popup.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);

// Section A — Entity Index Explorer panels (self-registering IIFE modules)
$this->headScript()->appendFile($this->assetUrl('js/charts/index-overview/stats.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/index-overview/type-distribution.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/index-overview/top-entities.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/index-overview/lifespan.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/index-overview/places-map.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/index-overview/activity-gantt.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);
$this->headScript()->appendFile($this->assetUrl('js/charts/index-overview/index-table.min.js', 'IwacVisualizations'), 'text/javascript', ['defer' => 'defer']);

// Section B — Keyword Explorer panels
