<?php
/**
 * Collection Overview — server-rendered fallback.
 *
 * Renders the period covered and a growth sparkline from the precomputed
 * snapshot, so crawlers and no-JS / slow clients get real data instead of a
 * "Loading…" spinner. The live ECharts dashboard (collection-overview.js →
 * buildLayout) clears the wrapper and replaces this on hydration, so the
 * markup mirrors the client's buildPeriodSubtitle() output for a seamless
 * swap.
 *
 * The headline KPI cards used to live here too, but those figures (counts +
 * corpus-depth stats) now render in the IWAC-theme homepage hero, which reads
 * the same snapshot — so this fallback (and buildLayout) no longer duplicate
 * them.
 *
 * Any missing field is skipped; the caller only includes this partial when
 * the snapshot decoded to a summary, so this template assumes $summary is
 * a non-empty array.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var array       $summary      The snapshot's `summary` object.
 * @var array|null  $growth       The snapshot's `growth` object (for the sparkline).
 */
$escapeHtml = $this->plugin('escapeHtml');
$escapeAttr = $this->plugin('escapeHtmlAttr');
$translate  = $this->plugin('translate');

$yearMin = $summary['year_min'] ?? null;
$yearMax = $summary['year_max'] ?? null;

// Sparkline of the headline series (cumulative collection growth). Normalised
// into a 0–100 × 0–28 viewBox; a non-scaling stroke keeps it crisp when the
// viewBox is stretched to the container width.
$sparkPoints = '';
if (is_array($growth) && isset($growth['cumulative_total']) && is_array($growth['cumulative_total'])) {
    $vals = array_values(array_filter($growth['cumulative_total'], 'is_numeric'));
    $count = count($vals);
    if ($count >= 2) {
        $min = min($vals);
        $max = max($vals);
        $range = ($max - $min) ?: 1;
        $w = 100;
        $h = 28;
        $pts = [];
        foreach ($vals as $i => $v) {
            $x = ($i / ($count - 1)) * $w;
            $y = $h - (($v - $min) / $range) * $h;
            $pts[] = round($x, 2) . ',' . round($y, 2);
        }
        $sparkPoints = implode(' ', $pts);
    }
}
?>
<div class="iwac-vis-overview-root iwac-vis-overview-fallback" data-overview-fallback>
    <?php if ($yearMin && $yearMax): ?>
    <p class="iwac-vis-overview-subtitle"><?= $escapeHtml(sprintf($translate('Period covered: %1$s – %2$s'), $yearMin, $yearMax)) ?></p>
    <?php endif; ?>
    <?php if ($sparkPoints !== ''): ?>
    <figure class="iwac-vis-overview-sparkline">
        <svg viewBox="0 0 100 28" preserveAspectRatio="none" focusable="false" role="img"
             aria-label="<?= $escapeAttr($translate('Collection growth over time')) ?>">
            <polyline points="<?= $escapeHtml($sparkPoints) ?>" fill="none" vector-effect="non-scaling-stroke" />
        </svg>
        <figcaption><?= $escapeHtml($translate('Collection growth over time')) ?></figcaption>
    </figure>
    <?php endif; ?>
</div>
