<?php
/**
 * IWAC Visualizations — shared asset loader partial.
 *
 * Every IWAC block enqueues the same set of stylesheets, CDN libraries,
 * and IWAC JS modules with only small differences — whether the block
 * needs maps, tables, facet buttons, etc. This partial centralizes all
 * of that so individual templates only declare *what* they need.
 *
 * CDN versions are pinned at the top of the file: single source of
 * truth for every IWAC block. Bump the three constants when upgrading.
 *
 * Usage:
 *
 *     <?php echo $this->partial('common/iwac-assets', [
 *         'blockCss'     => 'collection-overview',
 *         'needs'        => [
 *             'maplibre'     => true,
 *             'wordcloud'    => true,
 *             'chartOptions' => true,
 *             'facetButtons' => true,
 *             'table'        => true,
 *             'pagination'   => true,
 *             'layout'       => true,           // declarative dashboard layout
 *             'renderers'    => [               // which shared renderers to load
 *                 'calendar-heatmap',
 *                 'chord',
 *                 'radar-profile',
 *                 'sibling-sparkline',
 *                 'similar-items',
 *                 'sunburst',
 *                 'treemap',
 *             ],
 *         ],
 *         'panels'       => [
 *             'collection-overview/recent-additions',
 *             'collection-overview/languages',
 *             // ...
 *         ],
 *         'orchestrator' => 'collection-overview',
 *     ]); ?>
 *
 * Load order is fixed: stylesheets → CDN libs → IWAC i18n/theme/core →
 * shared primitives → dashboard-layout (if needed) → shared renderers
 * (if needed) → block panels → orchestrator. headScript/headLink
 * de-dupe by URL, so if two partial calls ever clash on a page, each
 * asset is still emitted only once.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var string|null $blockCss
 * @var array|null  $needs
 * @var array|null  $panels
 * @var string|null $orchestrator
 */

// -- CDN versions -------------------------------------------------------
// Single source of truth. `@6` / `@5` / `@2` hold the major version and
// let patch releases through. Pin tighter (e.g. `@6.0.4`) if a specific
// upstream release causes regressions.
$cdnEcharts     = 'https://cdn.jsdelivr.net/npm/echarts@6/dist/echarts.min.js';
$cdnWordcloud   = 'https://cdn.jsdelivr.net/npm/echarts-wordcloud@2/dist/echarts-wordcloud.min.js';
$cdnMaplibreJs  = 'https://cdn.jsdelivr.net/npm/maplibre-gl@5/dist/maplibre-gl.js';
$cdnMaplibreCss = 'https://cdn.jsdelivr.net/npm/maplibre-gl@5/dist/maplibre-gl.css';

// -- Defaults -----------------------------------------------------------
$blockCss     = isset($blockCss)     ? $blockCss     : null;
$needs        = isset($needs)        ? (array) $needs : [];
$panels       = isset($panels)       ? (array) $panels : [];
$orchestrator = isset($orchestrator) ? $orchestrator : null;

$needMaplibre   = !empty($needs['maplibre']);
$needWordcloud  = !empty($needs['wordcloud']);
$needChartOpts  = !empty($needs['chartOptions']);
// `table` implicitly needs pagination — pagination.js is table.js's dep.
$needPagination = !empty($needs['pagination']) || !empty($needs['table']);
$needTable      = !empty($needs['table']);
$needFacets     = !empty($needs['facetButtons']);
// Renderers imply the dashboard-layout module they register against.
$rendererList   = isset($needs['renderers']) ? (array) $needs['renderers'] : [];
$needLayout     = !empty($needs['layout']) || !empty($rendererList);

$module = 'IwacVisualizations';
$defer  = ['defer' => 'defer'];

$headLink   = $this->headLink();
$headScript = $this->headScript();

// -- Stylesheets --------------------------------------------------------
$headLink->appendStylesheet($this->assetUrl('css/iwac-core.css', $module));
if ($needMaplibre) {
    $headLink->appendStylesheet($this->assetUrl('css/iwac-maplibre.css', $module));
}
if ($blockCss) {
    $headLink->appendStylesheet($this->assetUrl('css/blocks/' . $blockCss . '.css', $module));
}

// -- CDN JS libraries ---------------------------------------------------
$headScript->appendFile($cdnEcharts, 'text/javascript', $defer);
if ($needWordcloud) {
    $headScript->appendFile($cdnWordcloud, 'text/javascript', $defer);
}
if ($needMaplibre) {
    $headScript->appendFile($cdnMaplibreJs, 'text/javascript', $defer);
    $headLink->appendStylesheet($cdnMaplibreCss);
}

// -- IWAC infrastructure (i18n → theme → dashboard-core) ---------------
$headScript->appendFile($this->assetUrl('js/iwac-i18n.min.js', $module), 'text/javascript', $defer);
$headScript->appendFile($this->assetUrl('js/iwac-theme.min.js', $module), 'text/javascript', $defer);
$headScript->appendFile($this->assetUrl('js/dashboard-core.min.js', $module), 'text/javascript', $defer);

// -- Shared primitives --------------------------------------------------
// panels.js is the base for every other primitive and is always loaded.
// panel-toolbar + responsive are tiny and universally useful, so they
// load unconditionally too. Heavier or feature-specific primitives
// (chart-options, table, pagination, facet-buttons+faceted-chart,
// maplibre, map-popup) are opt-in via $needs.
$headScript->appendFile($this->assetUrl('js/charts/shared/panels.min.js',        $module), 'text/javascript', $defer);
$headScript->appendFile($this->assetUrl('js/charts/shared/panel-toolbar.min.js', $module), 'text/javascript', $defer);
$headScript->appendFile($this->assetUrl('js/charts/shared/responsive.min.js',    $module), 'text/javascript', $defer);
if ($needChartOpts) {
    $headScript->appendFile($this->assetUrl('js/charts/shared/chart-options.min.js', $module), 'text/javascript', $defer);
}
if ($needPagination) {
    $headScript->appendFile($this->assetUrl('js/charts/shared/pagination.min.js', $module), 'text/javascript', $defer);
}
if ($needTable) {
    $headScript->appendFile($this->assetUrl('js/charts/shared/table.min.js', $module), 'text/javascript', $defer);
}
if ($needFacets) {
    $headScript->appendFile($this->assetUrl('js/charts/shared/facet-buttons.min.js',  $module), 'text/javascript', $defer);
    $headScript->appendFile($this->assetUrl('js/charts/shared/faceted-chart.min.js',  $module), 'text/javascript', $defer);
}
if ($needMaplibre) {
    $headScript->appendFile($this->assetUrl('js/charts/shared/maplibre.min.js',   $module), 'text/javascript', $defer);
    $headScript->appendFile($this->assetUrl('js/charts/shared/map-popup.min.js',  $module), 'text/javascript', $defer);
    $headScript->appendFile($this->assetUrl('js/charts/shared/choropleth.min.js', $module), 'text/javascript', $defer);
}

// -- Dashboard layout system + opt-in renderers ------------------------
//
// dashboard-layout.js is the registry; each renderer file under
// shared/renderers/ self-registers into it on load. Only the renderers
// the page declares are emitted, so blocks that don't use the layout
// system pay nothing.
if ($needLayout) {
    $headScript->appendFile($this->assetUrl('js/charts/shared/dashboard-layout.min.js', $module), 'text/javascript', $defer);
    foreach ($rendererList as $renderer) {
        // Sanitize: only allow [a-z0-9-] so the assetUrl path can't
        // be coerced into a directory traversal.
        $clean = preg_replace('/[^a-z0-9\-]/', '', strtolower((string) $renderer));
        if ($clean === '') {
            continue;
        }
        $headScript->appendFile(
            $this->assetUrl('js/charts/shared/renderers/' . $clean . '.min.js', $module),
            'text/javascript',
            $defer
        );
    }
}

// -- Block-specific panel modules --------------------------------------
foreach ($panels as $panel) {
    $headScript->appendFile($this->assetUrl('js/charts/' . $panel . '.min.js', $module), 'text/javascript', $defer);
}

// -- Orchestrator (LAST) -----------------------------------------------
if ($orchestrator) {
    $headScript->appendFile($this->assetUrl('js/charts/' . $orchestrator . '.min.js', $module), 'text/javascript', $defer);
}
