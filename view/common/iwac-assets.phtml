<?php
/**
 * IWAC Visualizations — shared asset loader partial.
 *
 * Every IWAC block enqueues the same set of stylesheets, CDN libraries,
 * and IWAC JS modules with only small differences — whether the block
 * needs maps, tables, facet buttons, etc. This partial centralizes all
 * of that so individual templates only declare *what* they need.
 *
 * CDN versions are pinned at the top of the file: single source of
 * truth for every IWAC block. Bump the three constants when upgrading.
 *
 * Usage:
 *
 *     <?php echo $this->partial('common/iwac-assets', [
 *         'blockCss'     => 'collection-overview',
 *         'needs'        => [
 *             'maplibre'     => true,
 *             'wordcloud'    => true,
 *             'chartOptions' => true,
 *             'facetButtons' => true,
 *             'table'        => true,
 *             'pagination'   => true,
 *             'layout'       => true,           // declarative dashboard layout
 *             'renderers'    => [               // which shared renderers to load
 *                 'calendar-heatmap',
 *                 'chord',
 *                 'radar-profile',
 *                 'sibling-sparkline',
 *                 'similar-items',
 *                 'sunburst',
 *                 'treemap',
 *             ],
 *         ],
 *         'panels'       => [
 *             'collection-overview/recent-additions',
 *             'collection-overview/languages',
 *             // ...
 *         ],
 *         'orchestrator' => 'collection-overview',
 *     ]); ?>
 *
 * Load order is fixed: stylesheets → CDN libs → IWAC i18n/theme/core →
 * shared primitives → dashboard-layout (if needed) → shared renderers
 * (if needed) → block panels → orchestrator. headScript/headLink
 * de-dupe by URL, so if two partial calls ever clash on a page, each
 * asset is still emitted only once.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var string|null $blockCss
 * @var array|null  $needs
 * @var array|null  $panels
 * @var string|null $orchestrator
 */

// -- CDN versions -------------------------------------------------------
// Single source of truth, pinned to EXACT versions. Floating major tags
// (`@6`) resolve through a short-TTL redirect and silently upgrade the
// live site to untested releases (6.1.0 landed that way on 2026-05-19);
// exact pins are immutable-cached by jsDelivr for a year and make every
// upgrade a deliberate, testable bump of these constants.
$cdnEcharts     = 'https://cdn.jsdelivr.net/npm/echarts@6.1.0/dist/echarts.min.js';
$cdnWordcloud   = 'https://cdn.jsdelivr.net/npm/echarts-wordcloud@2.1.0/dist/echarts-wordcloud.min.js';
$cdnMaplibreJs  = 'https://cdn.jsdelivr.net/npm/maplibre-gl@5.24.0/dist/maplibre-gl.js';
$cdnMaplibreCss = 'https://cdn.jsdelivr.net/npm/maplibre-gl@5.24.0/dist/maplibre-gl.css';

// -- Defaults -----------------------------------------------------------
$blockCss     = isset($blockCss)     ? $blockCss     : null;
$needs        = isset($needs)        ? (array) $needs : [];
$panels       = isset($panels)       ? (array) $panels : [];
$orchestrator = isset($orchestrator) ? $orchestrator : null;

$needMaplibre   = !empty($needs['maplibre']);
$needWordcloud  = !empty($needs['wordcloud']);
$needChartOpts  = !empty($needs['chartOptions']);
// `table` implicitly needs pagination — pagination.js is table.js's dep.
$needPagination = !empty($needs['pagination']) || !empty($needs['table']);
$needTable      = !empty($needs['table']);
$needFacets     = !empty($needs['facetButtons']);
// Renderers imply the dashboard-layout module they register against.
$rendererList   = isset($needs['renderers']) ? (array) $needs['renderers'] : [];
$needLayout     = !empty($needs['layout']) || !empty($rendererList);

$module = 'IwacVisualizations';

$headLink   = $this->headLink();
$headScript = $this->headScript();

// -- CDN preconnect ------------------------------------------------------
// The on-view lazy loader (bottom of this file) injects the chart
// libraries only when a block nears the viewport — without this hint the
// very first library request also pays DNS + TCP + TLS (~100-200 ms).
// Classic <script>/<link> fetches are non-CORS, so no crossorigin variant
// is needed (a crossorigin preconnect would open a second, unused socket).
$headLink(['rel' => 'preconnect',   'href' => 'https://cdn.jsdelivr.net'], 'PREPEND');
$headLink(['rel' => 'dns-prefetch', 'href' => 'https://cdn.jsdelivr.net'], 'PREPEND');

// -- Stylesheets (minified; regenerate with `npm run build:css`) --------
$headLink->appendStylesheet($this->assetUrl('css/iwac-core.min.css', $module));
if ($needMaplibre) {
    $headLink->appendStylesheet($this->assetUrl('css/iwac-maplibre.min.css', $module));
}
if ($blockCss) {
    $headLink->appendStylesheet($this->assetUrl('css/blocks/' . $blockCss . '.min.css', $module));
}

// -- Deferred, on-view asset loading -----------------------------------
//
// IWAC dashboards live below the fold, but the libraries they need are heavy
// (echarts ~640 KB + maplibre ~360 KB + wordcloud parse/exec dominate the
// homepage's main-thread time). Rather than emit ~30 eager `<script defer>`
// tags that all download + execute during page load, we collect the ordered
// script list here and hand it to a tiny inline loader (below) that injects
// them — in order, via `async=false` — only once a `.iwac-vis-block` nears the
// viewport. No orchestrator code changes: the same scripts run in the same
// order, just later. If IntersectionObserver is unavailable or no block marker
// is found, the loader falls back to loading immediately, so a chart can never
// be stranded behind its spinner.
//
// $scripts preserves the previous load order exactly: CDN libs → IWAC
// infra (i18n → theme → core) → shared primitives → conditional features →
// dashboard-layout + renderers → block panels → orchestrator (last).
$scripts = [];

// CDN libraries (echarts must precede the IWAC theme + panels).
$scripts[] = $cdnEcharts;
if ($needWordcloud) {
    $scripts[] = $cdnWordcloud;
}
$mapCss = null;
if ($needMaplibre) {
    $scripts[] = $cdnMaplibreJs;
    // The map renders on-view only, so its stylesheet rides along with the
    // loader instead of render-blocking the whole page from a CDN.
    $mapCss = $cdnMaplibreCss;
}

// IWAC infrastructure (i18n → theme → dashboard-core).
$scripts[] = $this->assetUrl('js/iwac-i18n.min.js', $module);
$scripts[] = $this->assetUrl('js/iwac-theme.min.js', $module);
$scripts[] = $this->assetUrl('js/dashboard-core.min.js', $module);

// Shared primitives — panels is the base for every other primitive;
// panel-toolbar + responsive are tiny and universally useful. Heavier or
// feature-specific primitives are opt-in via $needs.
$scripts[] = $this->assetUrl('js/charts/shared/panels.min.js', $module);
$scripts[] = $this->assetUrl('js/charts/shared/panel-toolbar.min.js', $module);
$scripts[] = $this->assetUrl('js/charts/shared/responsive.min.js', $module);
if ($needChartOpts) {
    // chart-options core must load before its four family builders, which
    // extend the same IWACVis.chartOptions namespace in any order.
    $scripts[] = $this->assetUrl('js/charts/shared/chart-options.min.js', $module);
    $scripts[] = $this->assetUrl('js/charts/shared/chart-options-bar.min.js', $module);
    $scripts[] = $this->assetUrl('js/charts/shared/chart-options-hbar.min.js', $module);
    $scripts[] = $this->assetUrl('js/charts/shared/chart-options-graph.min.js', $module);
    $scripts[] = $this->assetUrl('js/charts/shared/chart-options-special.min.js', $module);
}
if ($needPagination) {
    $scripts[] = $this->assetUrl('js/charts/shared/pagination.min.js', $module);
}
if ($needTable) {
    $scripts[] = $this->assetUrl('js/charts/shared/table.min.js', $module);
}
if ($needFacets) {
    $scripts[] = $this->assetUrl('js/charts/shared/facet-buttons.min.js', $module);
    $scripts[] = $this->assetUrl('js/charts/shared/faceted-chart.min.js', $module);
}
if ($needMaplibre) {
    $scripts[] = $this->assetUrl('js/charts/shared/maplibre.min.js', $module);
    $scripts[] = $this->assetUrl('js/charts/shared/map-popup.min.js', $module);
    $scripts[] = $this->assetUrl('js/charts/shared/choropleth.min.js', $module);
}

// Dashboard layout system + opt-in renderers (each renderer self-registers
// into dashboard-layout on load; only declared renderers are emitted).
if ($needLayout) {
    $scripts[] = $this->assetUrl('js/charts/shared/dashboard-layout.min.js', $module);
    foreach ($rendererList as $renderer) {
        // Sanitize: only [a-z0-9-] so the assetUrl path can't be coerced
        // into a directory traversal.
        $clean = preg_replace('/[^a-z0-9\-]/', '', strtolower((string) $renderer));
        if ($clean === '') {
            continue;
        }
        $scripts[] = $this->assetUrl('js/charts/shared/renderers/' . $clean . '.min.js', $module);
    }
}

// Block-specific panel modules, then the orchestrator (LAST).
foreach ($panels as $panel) {
    $scripts[] = $this->assetUrl('js/charts/' . $panel . '.min.js', $module);
}
if ($orchestrator) {
    $scripts[] = $this->assetUrl('js/charts/' . $orchestrator . '.min.js', $module);
}

// -- On-view loader -----------------------------------------------------
// Emitted per block; multiple blocks on one page merge their script lists
// into the same window.IWACVisLazy queue at runtime and only the first arms
// the IntersectionObserver. json_encode keeps slashes escaped so the inline
// payload can never break out of the <script> element.
$payload = json_encode(['scripts' => $scripts, 'mapCss' => $mapCss]);
$headScript->appendScript(
    '(function(){'
    . 'var S=window.IWACVisLazy=(window.IWACVisLazy||{q:[],css:null,armed:false,done:false});'
    . 'var p=' . $payload . ';'
    . 'p.scripts.forEach(function(u){if(S.q.indexOf(u)<0)S.q.push(u);});'
    . 'if(p.mapCss&&!S.css)S.css=p.mapCss;'
    . 'if(S.armed)return;S.armed=true;'
    . 'function load(){if(S.done)return;S.done=true;'
    . 'if(S.css){var l=document.createElement("link");l.rel="stylesheet";l.href=S.css;document.head.appendChild(l);}'
    . 'S.q.forEach(function(src){var s=document.createElement("script");s.src=src;s.async=false;document.head.appendChild(s);});'
    . '}'
    . 'function arm(){var b=document.querySelectorAll(".iwac-vis-block");'
    . 'if(!b.length||!("IntersectionObserver" in window)){load();return;}'
    . 'var io=new IntersectionObserver(function(en){for(var i=0;i<en.length;i++){if(en[i].isIntersecting){io.disconnect();load();return;}}},{rootMargin:"400px 0px"});'
    . 'for(var i=0;i<b.length;i++)io.observe(b[i]);'
    . '}'
    . 'if(document.readyState==="loading"){document.addEventListener("DOMContentLoaded",arm);}else{arm();}'
    . '})();'
);
