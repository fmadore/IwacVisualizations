</style>

<div class="iwac-embed-wrap">
    <h1><?= $escapeHtml($this->translate('Embed IWAC visualizations')) ?></h1>
    <p class="lede"><?= $escapeHtml($this->translate(
        'Copy a snippet below to embed any visualization on another website. Each iframe loads live from this site and resizes itself to fit.'
    )) ?></p>

    <?php foreach ($blocks as $slug => $label): ?>
        <?php
        // Preview loads same-origin (relative path); the copy snippet is built
        // client-side with an absolute URL via IWACVis.embed.
        $previewSrc = $this->url('site/iwac-embed/block', [
            'site-slug' => $siteSlug,
            'block'     => $slug,
        ]);
        ?>
        <section class="iwac-embed-card" data-slug="<?= $escapeAttr($slug) ?>"
                 data-site-base="<?= $escapeAttr($siteBase) ?>"
                 data-label="<?= $escapeAttr($this->translate($label)) ?>">
            <header>
                <h2><?= $escapeHtml($this->translate($label)) ?></h2>
                <span class="slug"><?= $escapeHtml($slug) ?></span>
            </header>
            <iframe class="iwac-embed-preview" src="<?= $escapeAttr($previewSrc) ?>"
                    title="<?= $escapeAttr($label) ?>" loading="lazy"></iframe>
            <div class="iwac-embed-code">
                <button type="button" class="iwac-embed-copy" data-embed-block>
                    <?= $escapeHtml($this->translate('Copy')) ?>
                </button>
                <pre><code class="iwac-embed-snippet"></code></pre>
            </div>
            <div class="iwac-embed-panels" hidden>
                <p class="iwac-embed-panels-label"><?= $escapeHtml($this->translate('Embed a single panel')) ?></p>
                <ul class="iwac-embed-panel-list"></ul>
            </div>
        </section>
    <?php endforeach; ?>

    <p class="iwac-embed-note"><?= $this->translate(
        'Tip: embeds render in light mode by default; append <code>?theme=dark</code> for dark mode, or <code>?primary=2b6cb0</code> to override the accent colour.'
    ) ?></p>
</div>

<script>
(function () {
    var E = (window.IWACVis && window.IWACVis.embed) || null;
    var copyLabel = <?= json_encode($this->translate('Copy')) ?>;
    var doneLabel = <?= json_encode($this->translate('Copied!')) ?>;
    if (!E) return; // embed.js missing — leave the live previews as-is

    function wireCopy(btn, getText) {
        btn.addEventListener('click', function () {
            E.copyToClipboard(getText()).then(function () {
                btn.textContent = doneLabel;
                btn.classList.add('copied');
                setTimeout(function () { btn.textContent = copyLabel; btn.classList.remove('copied'); }, 1600);
            });
        });
    }

    Array.prototype.forEach.call(document.querySelectorAll('.iwac-embed-card'), function (card) {
        var slug = card.getAttribute('data-slug');
        var siteBase = card.getAttribute('data-site-base') || '';
        var label = card.getAttribute('data-label') || slug;
        var blockSnippet = E.snippet(E.url(siteBase, slug), label, 600);

        // Whole-block snippet → the <pre> + its Copy button.
        var code = card.querySelector('.iwac-embed-snippet');
        if (code) code.textContent = blockSnippet;
        var blockBtn = card.querySelector('[data-embed-block]');
        if (blockBtn) wireCopy(blockBtn, function () { return blockSnippet; });

        // Per-panel snippets: read the live preview (same origin) once it has
        // rendered, then enumerate its panels exactly as the embed route will,
        // so the panel-<n> slugs line up. Only shown for multi-panel blocks.
        var iframe = card.querySelector('.iwac-embed-preview');
        var panelsBox = card.querySelector('.iwac-embed-panels');
        var list = card.querySelector('.iwac-embed-panel-list');
        if (!iframe || !panelsBox || !list) return;

        function renderPanels(panels) {
            list.textContent = '';
            panels.forEach(function (info) {
                var title = info.title || info.slug;
                var snippet = E.snippet(E.url(siteBase, slug, info.slug), label + ' — ' + title, 520);
                var li = document.createElement('li');
                var name = document.createElement('span');
                name.className = 'iwac-embed-panel-name';
                name.textContent = title;
                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'iwac-embed-copy iwac-embed-copy--sm';
                btn.textContent = copyLabel;
                wireCopy(btn, function () { return snippet; });
                li.appendChild(name);
                li.appendChild(btn);
                list.appendChild(li);
            });
            panelsBox.hidden = false;
        }

        function tryEnumerate(attemptsLeft) {
            var doc;
            try { doc = iframe.contentDocument; } catch (e) { return; } // cross-origin guard
            var block = doc && doc.querySelector('.iwac-vis-block');
            var panels = block ? E.enumeratePanels(block) : [];
            if (panels.length > 1) {
                renderPanels(panels);
            } else if (attemptsLeft > 0) {
                setTimeout(function () { tryEnumerate(attemptsLeft - 1); }, 400);
            }
        }

        iframe.addEventListener('load', function () { tryEnumerate(12); });
        // Already loaded (cache) before the listener attached.
        try {
            if (iframe.contentDocument && iframe.contentDocument.readyState === 'complete') {
                tryEnumerate(12);
            }
        } catch (e) { /* cross-origin — ignore */ }
    });
})();
</script>
