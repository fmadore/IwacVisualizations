<?php
/**
 * Bare layout for the IWAC embed endpoint.
 *
 * Replaces the public theme's layout (set via the controller's
 * `layout()->setTemplate()`) so an embedded block renders without site
 * chrome — just the doctype, the head placeholders the block shell
 * populates (headLink / headScript), and the rendered block.
 *
 * The module's own CSS (iwac-core / iwac-maplibre / blocks/*) is enqueued
 * by the block partial through `common/iwac-assets`, so this layout only
 * adds the document scaffold plus an optional brand-accent override and a
 * tiny postMessage height reporter for iframe auto-resizing.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var string $content
 * @var string|null $embedTheme    'light' | 'dark' | '' (follow OS pref)
 * @var string|null $embedPrimary  '#rrggbb' accent override, or ''
 * @var string|null $embedTitle    Block label, for <title>
 * @var bool|null   $isGallery      True on the snippet-gallery page
 */
$escapeAttr = $this->plugin('escapeHtmlAttr');
$escapeHtml = $this->plugin('escapeHtml');

// <html lang> drives iwac-i18n's locale resolution; follow the site locale.
$locale = (string) ($this->siteSetting('locale') ?: $this->setting('locale') ?: 'en');
$locale = substr($locale, 0, 2) ?: 'en';

$embedTheme   = isset($embedTheme)   ? (string) $embedTheme : '';
$embedPrimary = isset($embedPrimary) ? (string) $embedPrimary : '';
$embedTitle   = isset($embedTitle)   ? (string) $embedTitle : 'IWAC Visualizations';
$isGallery    = !empty($isGallery);
?>
<!doctype html>
<html lang="<?= $escapeAttr($locale) ?>">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><?= $escapeHtml($embedTitle) ?></title>
    <?= $this->headLink() ?>
    <?= $this->headStyle() ?>
    <style>
        html, body { margin: 0; padding: 0; background: transparent; }
        body.iwac-embed-body { -webkit-text-size-adjust: 100%; }
        /* The block already self-paces; keep it edge-to-edge in the frame. */
        .iwac-embed-body .iwac-vis-block { margin: 0 auto; }
    </style>
    <?php if ($embedPrimary !== ''): ?>
    <style>:root { --primary: <?= $escapeAttr($embedPrimary) ?>; }</style>
    <?php endif; ?>
    <?= $this->headScript() ?>
</head>
<body class="iwac-embed-body<?= $isGallery ? ' iwac-embed-gallery' : '' ?>"<?php
    if ($embedTheme === 'light' || $embedTheme === 'dark'): ?> data-theme="<?= $escapeAttr($embedTheme) ?>"<?php endif; ?>>
<?= $content ?>
<?php if (!$isGallery): ?>
<script>
/* iframe height reporter — posts the document height to the parent on load,
   resize, and DOM mutations (charts populate asynchronously). The host page
   pairs this with the listener emitted in the embed snippet. */
(function () {
    if (window.parent === window) return;
    var last = 0;
    function post() {
        var h = Math.ceil(document.documentElement.getBoundingClientRect().height);
        if (h && h !== last) {
            last = h;
            window.parent.postMessage({ type: 'iwac-embed-height', height: h }, '*');
        }
    }
    window.addEventListener('load', post);
    window.addEventListener('resize', post);
    if ('ResizeObserver' in window) {
        new ResizeObserver(post).observe(document.body);
    } else {
        setInterval(post, 1000);
    }
    // Nudge a few times early, before charts finish their first paint.
    var t = 0, iv = setInterval(function () { post(); if (++t > 20) clearInterval(iv); }, 300);
})();
</script>
<?php endif; ?>
</body>
</html>
