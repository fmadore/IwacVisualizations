<?php
/**
 * Bare layout for the IWAC embed endpoint.
 *
 * Replaces the public theme's layout (set via the controller's
 * `layout()->setTemplate()`) so an embedded block renders without site
 * chrome — just the doctype, the head placeholders the block shell
 * populates (headLink / headScript), and the rendered block.
 *
 * The module's own CSS (iwac-core / iwac-maplibre / blocks/*) is enqueued
 * by the block partial through `common/iwac-assets`, so this layout only
 * adds the document scaffold plus an optional brand-accent override and a
 * tiny postMessage height reporter for iframe auto-resizing.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var string $content
 * @var string|null $embedTheme    'light' | 'dark' | '' (default: light)
 * @var string|null $embedPrimary  '#rrggbb' accent override, or ''
 * @var string|null $embedTitle    Block label, for <title>
 * @var string|null $embedPanel    Panel slug for a single-panel embed, or ''
 * @var bool|null   $isGallery      True on the snippet-gallery page
 */
$escapeAttr = $this->plugin('escapeHtmlAttr');
$escapeHtml = $this->plugin('escapeHtml');

// <html lang> drives iwac-i18n's locale resolution; follow the site locale.
$locale = (string) ($this->siteSetting('locale') ?: $this->setting('locale') ?: 'en');
$locale = substr($locale, 0, 2) ?: 'en';

$embedTheme   = isset($embedTheme)   ? (string) $embedTheme : '';
$embedPrimary = isset($embedPrimary) ? (string) $embedPrimary : '';
$embedTitle   = isset($embedTitle)   ? (string) $embedTitle : 'IWAC Visualizations';
$embedPanel   = isset($embedPanel)   ? (string) $embedPanel : '';
$isGallery    = !empty($isGallery);

// Embeds render LIGHT by default (see EmbedController): an iframe can't read
// its host page's colour scheme, so a fixed light mode is the predictable
// choice. ?theme=dark opts into dark. Stamp data-theme on BOTH <html> and
// <body> so the IWAC theme's prefers-color-scheme path can't override it.
$mode      = ($embedTheme === 'dark') ? 'dark' : 'light';
$themeAttr = ' data-theme="' . $escapeAttr($mode) . '"';

// Provenance link shown on every embedded block (not the gallery): a quiet
// "Source: <site>" back to the site this data lives on.
$site        = $this->currentSite();
$sourceUrl   = $site ? $site->siteUrl(null, true) : rtrim((string) $this->serverUrl(false), '/');
$sourceLabel = $this->translate('Source') . ': ' . ($site ? $site->title() : 'Islam West Africa Collection');

// Pull the live brand accent so the embed matches the site instead of the
// module's generic fallback. `?primary=` (already validated upstream) wins;
// otherwise read the IWAC theme's admin-set `primary_color` / `secondary_color`
// settings. Without the compiled theme CSS on this bare route these tokens
// would otherwise fall back to module defaults. Only accept clean hex.
$hex = function ($v) {
    $v = trim((string) $v);
    return preg_match('/^#?[0-9a-fA-F]{3}([0-9a-fA-F]{3}([0-9a-fA-F]{2})?)?$/', $v)
        ? '#' . ltrim($v, '#') : '';
};
$primary   = $embedPrimary !== '' ? $embedPrimary : $hex($this->themeSetting('primary_color', ''));
$secondary = $hex($this->themeSetting('secondary_color', ''));
?>
<!doctype html>
<html lang="<?= $escapeAttr($locale) ?>"<?= $themeAttr ?>>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><?= $escapeHtml($embedTitle) ?></title>
    <?= $this->headLink() ?>
    <?= $this->headStyle() ?>
    <style>
        html, body { margin: 0; padding: 0; background: transparent; }
        body.iwac-embed-body { -webkit-text-size-adjust: 100%; }
        /* The block already self-paces; keep it edge-to-edge in the frame. */
        .iwac-embed-body .iwac-vis-block { margin: 0 auto; }
        /* Source-attribution footer. Styled inline (with token fallbacks) so it
           reads correctly even on this bare route before iwac-core.css lands. */
        .iwac-embed-source {
            margin: 0;
            padding: var(--space-sm, 0.5rem) var(--space-md, 1rem);
            text-align: right;
            font-family: var(--font-body, system-ui, -apple-system, sans-serif);
            font-size: var(--text-xs, 0.8125rem);
            border-top: 1px solid var(--border-light, #e6e7eb);
            background: var(--surface, #fdfdfd);
        }
        .iwac-embed-source a { color: var(--ink-light, #535862); text-decoration: none; }
        .iwac-embed-source a:hover { color: var(--primary, #e64a19); text-decoration: underline; }
    </style>
    <?php if ($primary !== '' || $secondary !== ''): ?>
    <style>
        :root {<?php if ($primary !== ''): ?> --primary: <?= $escapeAttr($primary) ?>;<?php endif;
            if ($secondary !== ''): ?> --secondary: <?= $escapeAttr($secondary) ?>;<?php endif; ?> }
        /* Match the theme's dark-mode habit of lightening the accent
           (e.g. #e64a19 → #ec653f) rather than carrying the light value.
           The mode is always pinned via data-theme on this route (embeds
           default to light), so this is the only dark branch we need. */
        body[data-theme="dark"] {<?php if ($primary !== ''): ?> --primary: color-mix(in oklab, <?= $escapeAttr($primary) ?>, white 12%);<?php endif;
            if ($secondary !== ''): ?> --secondary: color-mix(in oklab, <?= $escapeAttr($secondary) ?>, white 14%);<?php endif; ?> }
    </style>
    <?php endif; ?>
    <?= $this->headScript() ?>
</head>
<body class="iwac-embed-body<?= $isGallery ? ' iwac-embed-gallery' : '' ?><?php
    echo $embedPanel !== '' ? ' iwac-embed-single' : ''; ?>"<?= $themeAttr ?><?php
    if ($embedPanel !== ''): ?> data-embed-panel="<?= $escapeAttr($embedPanel) ?>"<?php endif; ?>>
<?= $content ?>
<?php if (!$isGallery): ?>
<footer class="iwac-embed-source">
    <a href="<?= $escapeAttr($sourceUrl) ?>" target="_blank" rel="noopener"><?= $escapeHtml($sourceLabel) ?></a>
</footer>
<script>
/* iframe height reporter — posts the document height to the parent on load,
   resize, and DOM mutations (charts populate asynchronously). The host page
   pairs this with the listener emitted in the embed snippet. */
(function () {
    if (window.parent === window) return;
    var last = 0;
    function post() {
        var h = Math.ceil(document.documentElement.getBoundingClientRect().height);
        if (h && h !== last) {
            last = h;
            window.parent.postMessage({ type: 'iwac-embed-height', height: h }, '*');
        }
    }
    window.addEventListener('load', post);
    window.addEventListener('resize', post);
    if ('ResizeObserver' in window) {
        new ResizeObserver(post).observe(document.body);
    } else {
        setInterval(post, 1000);
    }
    // Nudge a few times early, before charts finish their first paint.
    var t = 0, iv = setInterval(function () { post(); if (++t > 20) clearInterval(iv); }, 300);
})();
</script>
<?php endif; ?>
</body>
</html>
